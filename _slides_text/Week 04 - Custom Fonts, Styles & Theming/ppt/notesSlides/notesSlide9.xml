:p><a:r><a:rPr lang="en-US" dirty="0" err="1"/><a:t>val</a:t></a:r><a:r><a:rPr lang="en-US" dirty="0"/><a:t> </a:t></a:r><a:r><a:rPr lang="en-US" dirty="0" err="1"/><a:t>systemBars</a:t></a:r><a:r><a:rPr lang="en-US" dirty="0"/><a:t> = </a:t></a:r><a:r><a:rPr lang="en-US" dirty="0" err="1"/><a:t>insets.getInsets</a:t></a:r><a:r><a:rPr lang="en-US" dirty="0"/><a:t>(</a:t></a:r><a:r><a:rPr lang="en-US" dirty="0" err="1"/><a:t>WindowInsetsCompat.Type.systemBars</a:t></a:r><a:r><a:rPr lang="en-US" dirty="0"/><a:t>())      // Get insets for status and navigation bars    </a:t></a:r><a:r><a:rPr lang="en-US" dirty="0" err="1"/><a:t>v.setPadding</a:t></a:r><a:r><a:rPr lang="en-US" dirty="0"/><a:t>(</a:t></a:r><a:r><a:rPr lang="en-US" dirty="0" err="1"/><a:t>systemBars.left</a:t></a:r><a:r><a:rPr lang="en-US" dirty="0"/><a:t>, </a:t></a:r><a:r><a:rPr lang="en-US" dirty="0" err="1"/><a:t>systemBars.top</a:t></a:r><a:r><a:rPr lang="en-US" dirty="0"/><a:t>, </a:t></a:r><a:r><a:rPr lang="en-US" dirty="0" err="1"/><a:t>systemBars.right</a:t></a:r><a:r><a:rPr lang="en-US" dirty="0"/><a:t>, </a:t></a:r><a:r><a:rPr lang="en-US" dirty="0" err="1"/><a:t>systemBars.bottom</a:t></a:r><a:r><a:rPr lang="en-US" dirty="0"/><a:t>)  // Apply insets as padding to the root view    </a:t></a:r></a:p><a:p><a:r><a:rPr lang="en-US" dirty="0"/><a:t>insets     // Return Insets to indicate they were handled}</a:t></a:r></a:p><a:p><a:r><a:rPr lang="en-US" dirty="0" err="1"/><a:t>val</a:t></a:r><a:r><a:rPr lang="en-US" dirty="0"/><a:t> typeface = </a:t></a:r><a:r><a:rPr lang="en-US" dirty="0" err="1"/><a:t>ResourcesCompat.getFont</a:t></a:r><a:r><a:rPr lang="en-US" dirty="0"/><a:t>(this, </a:t></a:r><a:r><a:rPr lang="en-US" dirty="0" err="1"/><a:t>R.font.al_mushaf</a:t></a:r><a:r><a:rPr lang="en-US" dirty="0"/><a:t>)                 // Load custom “</a:t></a:r><a:r><a:rPr lang="en-US" dirty="0" err="1"/><a:t>al_mushaf</a:t></a:r><a:r><a:rPr lang="en-US" dirty="0"/><a:t>” font from res/font</a:t></a:r></