-US" dirty="0"/><a:t>(</a:t></a:r><a:r><a:rPr lang="en-US" dirty="0" err="1"/><a:t>R.id.main</a:t></a:r><a:r><a:rPr lang="en-US" dirty="0"/><a:t>)) { v, insets -&gt;</a:t></a:r></a:p><a:p><a:r><a:rPr lang="en-US" dirty="0"/><a:t>    // Query the size of system bars (status + navigation)    </a:t></a:r><a:r><a:rPr lang="en-US" dirty="0" err="1"/><a:t>val</a:t></a:r><a:r><a:rPr lang="en-US" dirty="0"/><a:t> </a:t></a:r><a:r><a:rPr lang="en-US" dirty="0" err="1"/><a:t>systemBars</a:t></a:r><a:r><a:rPr lang="en-US" dirty="0"/><a:t> = </a:t></a:r><a:r><a:rPr lang="en-US" dirty="0" err="1"/><a:t>insets.getInsets</a:t></a:r><a:r><a:rPr lang="en-US" dirty="0"/><a:t>(</a:t></a:r><a:r><a:rPr lang="en-US" dirty="0" err="1"/><a:t>WindowInsetsCompat.Type.systemBars</a:t></a:r><a:r><a:rPr lang="en-US" dirty="0"/><a:t>())</a:t></a:r></a:p><a:p><a:r><a:rPr lang="en-US" dirty="0"/><a:t>    // Apply those insets as padding so content isn’t obscured    </a:t></a:r><a:r><a:rPr lang="en-US" dirty="0" err="1"/><a:t>v.setPadding</a:t></a:r><a:r><a:rPr lang="en-US" dirty="0"/><a:t>(</a:t></a:r><a:r><a:rPr lang="en-US" dirty="0" err="1"/><a:t>systemBars.left</a:t></a:r><a:r><a:rPr lang="en-US" dirty="0"/><a:t>, </a:t></a:r><a:r><a:rPr lang="en-US" dirty="0" err="1"/><a:t>systemBars.top</a:t></a:r><a:r><a:rPr lang="en-US" dirty="0"/><a:t>, </a:t></a:r><a:r><a:rPr lang="en-US" dirty="0" err="1"/><a:t>systemBars.right</a:t></a:r><a:r><a:rPr lang="en-US" dirty="0"/><a:t>, </a:t></a:r><a:r><a:rPr lang="en-US" dirty="0" err="1"/><a:t>systemBars.bottom</a:t></a:r><a:r><a:rPr lang="en-US" dirty="0"/><a:t>)</a:t></a:r></a:p><a:p><a:r><a:rPr lang="en-US" dirty="0"/><a:t>    insets  // Return the insets to indicate they’ve been handled}</a:t></a:r></a:p><a:p><a:endParaRPr lang="en-US" dirty="0"/></a:p><a:p><a:r><a:rPr lang="en-US" dirty="0"/><a:t>// Bind the Bismillah </a:t></a:r><a:r><a:rPr lang="en-US" dirty="0" err="1"/><a:t>TextView</a:t></a:r><a:r><a:rPr lang="en-US" dirty="0"/><a:t> from the layout  </a:t></a:r><a:r><a:rPr lang="en-US" dirty="0" err="1"/><a:t>tv_bismillah</a:t></a:r><a:r><a:rPr lang="en-US" dirty="0"/><a:t> = </a:t></a:r><a:r><a:rPr lang="en-US" dirty="0" err="1"/><a:t>findViewById</a:t></a:r><a:r><a:rPr lang="en-US" dirty="0"/><a:t>(</a:t></a:r><a:r><a:rPr lang="en-US" dirty="0" err="1"/><a:t>R.id.tv_bismillah</a:t></a:r><a:r><a:rPr lang="en-US" dirty="0"/><a:t>)  </a:t></a:r></a:p><a:p><a:endParaRPr lang="en-US" dirty="0"/></a:p><a:p><a:r><a:rPr lang="en-US" dirty="0"/><a:t>// To apply your </a:t></a:r><a:r><a:rPr lang="en-US" dirty="0" err="1"/><a:t>TextStyle_Urdu</a:t></a:r><a:r><a:rPr lang="en-US" dirty="0"/><a:t> style resource at runtime, uncomment one of the following:</a:t></a:r></a:p><a:p><a:r><a:rPr lang="en-US" dirty="0"/><a:t>// Option 1: On API 23+ (Marshmallow and above)  // </a:t></a:r><a:r><a:rPr lang="en-US" dirty="0" err="1"/><a:t>tv_bismillah.setTextAppearance</a:t></a:r><a:r><a:rPr lang="en-US" dirty="0"/><a:t>(</a:t></a:r><a:r><a:rPr lang="en-US" dirty="0" err="1"/><a:t>R.style.TextStyle_Urdu</a:t></a:r><a:r><a:rPr lang="en-US" dirty="0"/><a:t>)  </a:t></a:r></a:p><a:p><a:r><a:rPr lang="en-US" dirty="0"/><a:t>// Option 2: For full backward-compatibility  // </a:t></a:r><a:r><a:rPr lang="en-US" dirty="0" err="1"/><a:t>androidx.core.widget.TextViewCompat.setTextAppearance</a:t></a:r><a:r><a:rPr lang="en-US" dirty="0"/><a:t>(//     </a:t></a:r><a:r><a:rPr lang="en-US" dirty="0" err="1"/><a:t>tv_bismillah</a:t></a:r><a:r><a:rPr lang="en-US" dirty="0"/><a:t>, //     </a:t></a:r><a:r><a:rPr lang="en-US" dirty="0" err="1"/><a:t>R.style.TextStyle_Urdu</a:t></a:r><a:endParaRPr lang="en-US" dirty="0"/></a:p><a:p><a:endParaRPr lang="en-US" dirty="0"/></a:p></p:txBody></p:sp><p:sp><p:nvSpPr><p:cNvPr id="4" name="Slide Number Placeholder 3"><a:extLst><a:ext uri="{FF2B5EF4-FFF2-40B4-BE49-F238E27FC236}"><a16:creationId xmlns:a16="http://schemas.microsoft.com/office/drawing/2014/main" id="{39BE67B0-7847-D93C-6266-4ED1DA9D0943}"/></a: