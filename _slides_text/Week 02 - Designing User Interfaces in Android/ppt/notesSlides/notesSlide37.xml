r="1"/><a:t>val</a:t></a:r><a:r><a:rPr lang="en-US" dirty="0"/><a:t> </a:t></a:r><a:r><a:rPr lang="en-US" dirty="0" err="1"/><a:t>weightStr</a:t></a:r><a:r><a:rPr lang="en-US" dirty="0"/><a:t> = </a:t></a:r><a:r><a:rPr lang="en-US" dirty="0" err="1"/><a:t>etWeight.text.toString</a:t></a:r><a:r><a:rPr lang="en-US" dirty="0"/><a:t>()</a:t></a:r></a:p><a:p><a:r><a:rPr lang="en-US" dirty="0"/><a:t>    </a:t></a:r><a:r><a:rPr lang="en-US" dirty="0" err="1"/><a:t>val</a:t></a:r><a:r><a:rPr lang="en-US" dirty="0"/><a:t> </a:t></a:r><a:r><a:rPr lang="en-US" dirty="0" err="1"/><a:t>heightStr</a:t></a:r><a:r><a:rPr lang="en-US" dirty="0"/><a:t> = </a:t></a:r><a:r><a:rPr lang="en-US" dirty="0" err="1"/><a:t>etHeight.text.toString</a:t></a:r><a:r><a:rPr lang="en-US" dirty="0"/><a:t>()</a:t></a:r></a:p><a:p><a:endParaRPr lang="en-US" dirty="0"/></a:p><a:p><a:r><a:rPr lang="en-US" dirty="0"/><a:t>    // Check if both inputs are non-empty before proceeding    </a:t></a:r></a:p><a:p><a:r><a:rPr lang="en-US" dirty="0"/><a:t>        if (</a:t></a:r><a:r><a:rPr lang="en-US" dirty="0" err="1"/><a:t>weightStr.isNotEmpty</a:t></a:r><a:r><a:rPr lang="en-US" dirty="0"/><a:t>() &amp;&amp; </a:t></a:r><a:r><a:rPr lang="en-US" dirty="0" err="1"/><a:t>heightStr.isNotEmpty</a:t></a:r><a:r><a:rPr lang="en-US" dirty="0"/><a:t>()) {</a:t></a:r></a:p><a:p><a:r><a:rPr lang="en-US" dirty="0"/><a:t>        </a:t></a:r><a:r><a:rPr lang="en-US" dirty="0" err="1"/><a:t>val</a:t></a:r><a:r><a:rPr lang="en-US" dirty="0"/><a:t> weight = </a:t></a:r><a:r><a:rPr lang="en-US" dirty="0" err="1"/><a:t>weightStr.toDouble</a:t></a:r><a:r><a:rPr lang="en-US" dirty="0"/><a:t>()          // Convert weight string to Double        </a:t></a:r></a:p><a:p><a:r><a:rPr lang="en-US" dirty="0"/><a:t>        </a:t></a:r><a:r><a:rPr lang="en-US" dirty="0" err="1"/><a:t>val</a:t></a:r><a:r><a:rPr lang="en-US" dirty="0"/><a:t> height = </a:t></a:r><a:r><a:rPr lang="en-US" dirty="0" err="1"/><a:t>heightStr.toDouble</a:t></a:r><a:r><a:rPr lang="en-US" dirty="0"/><a:t>()          // Convert height string to Double</a:t></a:r></a:p><a:p><a:r><a:rPr lang="en-US" dirty="0"/><a:t>        </a:t></a:r><a:r><a:rPr lang="en-US" dirty="0" err="1"/><a:t>val</a:t></a:r><a:r><a:rPr lang="en-US" dirty="0"/><a:t> </a:t></a:r><a:r><a:rPr lang="en-US" dirty="0" err="1"/><a:t>bmi</a:t></a:r><a:r><a:rPr lang="en-US" dirty="0"/><a:t> = weight / (height * height)       // Calculate BMI using the formula: weight / height²</a:t></a:r></a:p><a:p><a:r><a:rPr lang="en-US" dirty="0"/><a:t>        // Determine BMI category based on standard ranges        </a:t></a:r></a:p><a:p><a:r><a:rPr lang="en-US" dirty="0"/><a:t>        </a:t></a:r><a:r><a:rPr lang="en-US" dirty="0" err="1"/><a:t>val</a:t></a:r><a:r><a:rPr lang="en-US" dirty="0"/><a:t> category = when {</a:t></a:r></a:p><a:p><a:r><a:rPr lang="en-US" dirty="0"/><a:t>            </a:t></a:r><a:r><a:rPr lang="en-US" dirty="0" err="1"/><a:t>bmi</a:t></a:r><a:r><a:rPr lang="en-US" dirty="0"/><a:t> &lt; 18.5 -&gt; "Underweight"</a:t></a:r></a:p><a:p><a:r><a:rPr lang="en-US" dirty="0"/><a:t>            </a:t></a:r><a:r><a:rPr lang="en-US" dirty="0" err="1"/><a:t>bmi</a:t></a:r><a:r><a:rPr lang="en-US" dirty="0"/><a:t> in 18.5..24.9 -&gt; "Normal weight"</a:t></a:r></a:p><a:p><a:r><a:rPr lang="en-US" dirty="0"/><a:t>            </a:t></a:r><a:r><a:rPr lang="en-US" dirty="0" err="1"/><a:t>bmi</a:t></a:r><a:r><a:rPr lang="en-US" dirty="0"/><a:t> in 25.0..29.9 -&gt; "Overweight"</a:t></a:r></a:p><a:p><a:r><a:rPr lang="en-US" dirty="0"/><a:t>            else -&gt; "Obese"</a:t></a:r></a:p><a:p><a:r><a:rPr lang="en-US" dirty="0"/><a:t>        }</a:t></a:r></a:p><a:p><a:endParaRPr lang="en-US" dirty="0"/></a:p><a:p><a:r><a:rPr lang="en-US" dirty="0"/><a:t> // Display formatted BMI result and category in the </a:t></a:r><a:r><a:rPr lang="en-US" dirty="0" err="1"/><a:t>TextView</a:t></a:r><a:r><a:rPr lang="en-US" dirty="0"/><a:t>        </a:t></a:r></a:p><a:p><a:r><a:rPr lang="en-US" dirty="0"/><a:t>           </a:t></a:r><a:r><a:rPr lang="en-US" dirty="0" err="1"/><a:t>tvResult.text</a:t></a:r><a:r><a:rPr lang="en-US" dirty="0"/><a:t> = "Your BMI is %.2f\n You are %</a:t></a:r><a:r><a:rPr lang="en-US" dirty="0" err="1"/><a:t>s".format</a:t></a:r><a:r><a:rPr lang="en-US" dirty="0"/><a:t>(</a:t></a:r><a:r><a:rPr lang="en-US" dirty="0" err="1"/><a:t>bmi</a:t></a:r><a:r><a:rPr lang="en-US" dirty="0"/><a:t>, category)</a:t></a:r></a:p><a:p><a:r><a:rPr lang="en-US" dirty="0"/><a:t>    } </a:t></a:r></a:p><a:p><a:r><a:rPr lang="en-US" dirty="0"/><a:t>else {</a:t></a:r></a:p><a:p><a:r><a:rPr lang="en-US" dirty="0"/><a:t>        // Show error message if inputs are missing       </a:t></a:r></a:p><a:p><a:r><a:rPr lang="en-US" dirty="0"/><a:t>           </a:t></a:r><a:r><a:rPr lang="en-US" dirty="0" err="1"/><a:t>tvResult.text</a:t></a:r><a:r><a:rPr lang="en-US" dirty="0"/><a:t> = "Please enter valid weight and height"</a:t></a:r></a:p><a:p><a:r><a:rPr lang="en-US" dirty="0"/><a:t>    }</a:t></a:r></a:p><a:p><a:endParaRPr lang="en-US" dirty="0"/></a:p></p:txBody></p:sp><p:sp><p:nvSpPr><p:cNvPr id="4" name="Slide Number Placeholder 3"><a:extLst><a:ext uri="{FF2B5EF4-FFF2-40B4-BE49-F238E27FC236}"><a16:creationId xmlns:a16="http://schemas.microsoft.com/office/drawing/2014/main" id="{C11F3D2B-ADA2-38AF-602F-A406FB7BF20F}"/></a:ext></a:extLst></p:cNvPr><p:cNvSpPr><a:spLocks noGrp="1"/></p:cNvSpPr><p:nvPr><p:ph type="sldNum" sz="quarter" idx="10"/></p:nvPr></p:nvSpPr><p:spPr/><p:txBody><a:bodyPr/><a:lstStyle/><a:p><a:fld id="{069058F2-1E6F-48F3-9AA6-C3C5EDC8CD65}" type="slidenum"><a:rPr lang="en-US" altLang="en-US" smtClean="0"/><a:pPr/><a:t>38</a:t></a:fld><a:endParaRPr lang="en-US" altLang="en-US"/></a:p></p:txBody></p:sp></p:spTree><p:extLst><p:ext uri="{BB962C8B-B14F-4D97-AF65-F5344CB8AC3E}"><p14:creationId xmlns:p14="http://schemas.microsoft.com/office/powerpoint/2010/main" val="2329796059"/></p:ext></p:extLst></p:cSld><p:clrMapOvr><a:masterClrMapping