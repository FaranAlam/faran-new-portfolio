# ===================================
# PORTFOLIO WEBSITE - Environment Variables
# ===================================
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local to version control!

# ===================================
# AUTHENTICATION & SECURITY
# ===================================

# Admin Login Credentials
# IMPORTANT: Generate a strong password hash using: npm run generate-password
ADMIN_EMAIL=your-admin-email@example.com
ADMIN_PASSWORD_HASH=your_bcrypt_hashed_password_here

# NextAuth Configuration
# Generate a random secret: openssl rand -base64 32
NEXTAUTH_SECRET=your_random_32_character_secret_here
NEXTAUTH_URL=http://localhost:3000

# ===================================
# DATABASE
# ===================================

# MongoDB Connection String
# Get from: https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/portfolio?retryWrites=true&w=majority

# ===================================
# EMAIL SERVICE
# ===================================

# SMTP Email Configuration (Gmail example)
# For Gmail: Enable 2FA and generate an App Password
# Guide: https://support.google.com/accounts/answer/185833
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-specific-password

# Email Settings
EMAIL_FROM=your-email@gmail.com
EMAIL_FROM_NAME=Your Name

# ===================================
# API SERVICES
# ===================================

# AI Chat Service (OpenRouter)
# Get API key from: https://openrouter.ai
OPENROUTER_API_KEY=your_openrouter_api_key_here

# AI Model Configuration (optional)
AI_MODEL=meta-llama/llama-3.1-8b-instruct:free

# Backend API URL (if using separate backend)
NEXT_PUBLIC_API_URL=http://localhost:5000/api/v1

# ===================================
# PUBLIC CONFIGURATION
# ===================================

# Site URL (for emails and absolute URLs)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ===================================
# OPTIONAL SERVICES
# ===================================

# Google Analytics (optional)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Google Search Console (optional)
# GOOGLE_SITE_VERIFICATION=your_verification_code

# Sentry Error Tracking (optional)
# SENTRY_DSN=your_sentry_dsn

# ===================================
# DEVELOPMENT
# ===================================

# Node Environment
NODE_ENV=development

# Debug Mode (optional)
# DEBUG=true

# ===================================
# NOTES
# ===================================
# 1. To generate password hash: npm run generate-password
# 2. To generate NEXTAUTH_SECRET: openssl rand -base64 32
# 3. For production, use strong passwords and unique secrets
# 4. Keep this file updated when adding new environment variables

