MONGODB_URI=mongodb://faranalam14203:alam14203faran@ac-wlww6xe-shard-00-00.3j7tmok.mongodb.net:27017,ac-wlww6xe-shard-00-01.3j7tmok.mongodb.net:27017,ac-wlww6xe-shard-00-02.3j7tmok.mongodb.net:27017/portfolio?ssl=true&authSource=admin&retryWrites=true&w=majority

# Email Configuration (for email notifications)
# For Gmail: Use App Password (not regular password)
# 1. Go to Google Account → Security → 2-Step Verification (enable it)
# 2. Go to App Passwords: https://myaccount.google.com/apppasswords
# 3. Generate app password for "Mail" and "Other (Custom name)"
# 4. Copy the 16-character password and paste below
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_16_character_app_password

# Site URL (optional - for welcome email links)
NEXT_PUBLIC_SITE_URL=http://localhost:3005

# NextAuth Secret (REQUIRED for authentication)
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-generated-secret-key-here

# Admin Credentials
ADMIN_EMAIL=your_email@gmail.com
ADMIN_PASSWORD=your_secure_password_here

# AI Chat (OpenRouter - free model support)
# 1) Create free account at https://openrouter.ai
# 2) Generate an API key
# 3) Paste key below
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional: choose model (defaults to a free model)
# Example free models often include suffix like :free
AI_MODEL=meta-llama/llama-3.1-8b-instruct:free
